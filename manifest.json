{
  "manifest_version": 3,
  "name": "Speaky",
  "version": "0.1.0",
  "description": "Record any tab's audio and turn it into a transcript — Meet, Zoom, Teams, YouTube. Rust/WASM engine, local or cloud STT.",
  "permissions": ["activeTab", "storage", "tabs", "tabCapture", "offscreen", "sidePanel", "downloads"],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://huggingface.co/*",
    "https://*.hf.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://cas-bridge.xethub.hf.co/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "assets/Speaky-16.png",
    "48": "assets/Speaky-48.png",
    "128": "assets/Speaky-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "background": {
    "service_worker": "background/service_worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content/content_script.js"]
    }
  ],
  "action": {
    "default_title": "Speaky — open transcript panel",
    "default_icon": {
      "16": "assets/Speaky-16.png",
      "48": "assets/Speaky-48.png",
      "128": "assets/Speaky-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  }
}
